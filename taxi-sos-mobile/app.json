{
  "expo": {
    "name": "TaxiSOS",
    "slug": "taxi-sos-mobile",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "taxisosmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alihaydar.taksisos",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Bu uygulama acil durumlarda (SOS) veya canlı görüşmelerde kullanılmak üzere kameraya erişim gerektirebilir.",
        "NSMicrophoneUsageDescription": "Bu uygulama acil durumlarda (SOS) telsiz bağlantısı ile sesinizi diğer şoförlere iletmek için mikrofonunuza erişim gerektirir.",
        "UIBackgroundModes": [
          "audio",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "FOREGROUND_SERVICE_MICROPHONE",
        "RECORD_AUDIO",
        "WAKE_LOCK",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset",
      "expo-audio",
      "expo-font",
      "expo-video",
      "expo-notifications",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b2a85f3b-5ea9-4ce3-995d-b2a87aae98f9"
      }
    }
  }
}